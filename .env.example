# Email delivery (Resend). Leave empty in dev — submissions log to the server console.
RESEND_API_KEY=

# Where contact-form submissions should be delivered.
CONTACT_TO=fischer_eduard@yahoo.com

# Cloudflare Turnstile — site key is public (NEXT_PUBLIC_), secret stays server-only.
# Leave both empty to bypass captcha verification in dev.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# BVB live feed — no env vars required.
#
# /personal pulls live Bundesliga standings, BVB fixtures, and BVB results
# from OpenLigaDB (https://www.openligadb.de/). The API is public, free,
# and key-less, so there is nothing to set here. Data is cached server-
# side for 1 hour via Next.js ISR (`next: { revalidate: 3600 }`).
#
# If OpenLigaDB is unreachable the section renders an empty/unavailable
# state — there is no sample-data fallback. See src/lib/bvb.ts.

# --- Prototype features (only set on prototype env, never on prod) ---
# Each is "1" to enable, anything else (including unset) keeps the feature off.
# See docs/environments.md for the prototype env runbook.
NEXT_PUBLIC_PROTO_VIDEO_BG_FULL_BLEED=
NEXT_PUBLIC_PROTO_SIDE_SECTION_VIDEOS=
NEXT_PUBLIC_PROTO_ANIMATED_DIVIDERS=
NEXT_PUBLIC_PROTO_SCROLL_BG=
NEXT_PUBLIC_PROTO_PARALLAX_CARDS=

# --- Palette analytics (prototype track) ---
# See docs/palette-analytics-design.md
NEXT_PUBLIC_PROTO_PALETTE_TRACK=

# Visit-notification daily digest cron (see docs/visit-notification-design.md).
# Off by default — set NEXT_PUBLIC_PROTO_VISIT_DIGEST=1 in Vercel Production
# to enable (the cron route returns 404 until then). The CRON_SECRET is
# what Vercel signs the scheduled GET with — generate via
# `openssl rand -hex 32`. DAILY_SALT seeds the per-IP-hash anonymisation
# in `src/lib/visit-tracker.ts`; rotate at will.
NEXT_PUBLIC_PROTO_VISIT_DIGEST=
VISIT_DIGEST_ENABLED=
CRON_SECRET=
DAILY_SALT=
DIGEST_RECIPIENT=fischer_eduard@yahoo.com

# Vercel KV / Upstash Redis — optional. When set, /api/track-palette persists
# anonymous palette × theme × locale counters here. When unset, the route logs
# hits to stderr only. The KV_* names are what Vercel's KV integration injects;
# UPSTASH_REDIS_REST_URL/TOKEN are accepted as a manual override.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Admin secret — guards /admin/stats and the GET /api/track-palette read endpoint.
ADMIN_SECRET=

# Yahoo IMAP — only needed when running the live e2e contact-form
# round-trip with RUN_LIVE_EMAIL=1. The pass is a 16-char Yahoo *app
# password*, not the account password. See e2e/README.md.
YAHOO_IMAP_USER=
YAHOO_IMAP_APP_PASS=
