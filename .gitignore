# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local working logs
dev.log
install-utils.log
create-next-app.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# test outputs
/playwright-report
/test-results
/coverage

# downloaded design refs (local only)
.refs/
.claude/settings.local.json
.claude/worktrees/

# photo-catalogue intermediates (raw NDJSON dump from extract-exif.ps1)
scripts/.exif-raw.ndjson

# Lighthouse audit raw reports (regenerated via scripts/lighthouse-batch.mjs).
# Keep scores.md committed for historical context; per-route JSONs are
# huge and noisy. Re-run locally when needed.
docs/lighthouse-reports/*.json
.env*.local

# Scratch dirs from agent runs (Round 4/5 + EXIF tmp)
scripts/.round4/
scripts/.tmp-exif/
scripts/.gposze-*
scripts/.dportfolio-*
scripts/.israel-*
scripts/.catalogue-srcs.txt
scripts/round4-extension-*.json
scripts/.round5/agent-*-scratch/
scripts/.photo-classify/

# Inpaint pipeline (YOLO + LaMa) -- venv, model cache, and worktree-only
# test outputs. The python script (inpaint-people.py) IS committed.
# Re-create with: python -m venv scripts/.inpaint-venv && pip install ultralytics mediapipe Pillow simple-lama-inpainting
# (For GeoCLIP, also: scripts/.inpaint-venv/Scripts/pip.exe install geoclip "transformers<5")
scripts/.inpaint-venv/
scripts/.inpaint-cache/
scripts/.inpaint-test-output/
scripts/.inpaint-out/

# GeoCLIP run output (regenerated by scripts/run-geoclip.py from the catalogue).
# The script and the markdown sign-off doc ARE committed; the raw JSON dump
# is large and reproducible.
scripts/.geoclip-predictions.json
# Stray YOLO weights if Ultralytics drops them in CWD on first download.
yolo11n.pt
*.pt

# Inpaint edge-case corpus run outputs (regenerated by
# scripts/inpaint-edge-test.ps1; companion to docs/inpaint-edge-cases.md
# and PR #41). The script + JSON manifest IS committed.
scripts/.inpaint-edge-output/

# Aggressive person re-scan output (NDJSON log + flagged-srcs list).
# The python script (aggressive-person-rescan.py) IS committed; the run output
# is reproducible from the catalogue + thresholds documented in
# docs/aggressive-person-rescan.md.
scripts/.aggressive-rescan/

# Thin-trip backfill scratch (NDJSON detections + filter/import/doc helpers).
# scripts/thin-trip-detect.py IS committed.
scripts/.thin-trip-*

# Sub-agent worktrees
.claude/worktrees/

# Storybook build output (regenerated by `npm run build-storybook`).
/storybook-static/

# Transient build outputs (CV PDF builder uses /.cache for transpiled
# TS modules and /tmp for the smoke-test fixture output).
/.cache/
/tmp/

# Inpaint sweep intermediates: thumbnails (regenerated by
# scripts/generate-inpaint-review.mjs), staged inpaint output before sign-off,
# standalone test outputs from the inpaint Python pipeline, and the temporary
# before/after fixtures used by the SAMPLE doc dry-run.
public/photos/_inpaint-thumbs/
scripts/.inpaint-staging/
scripts/.inpaint-staging-israel-only/
scripts/.inpaint-test-output/
scripts/.inpaint-sample-before/
scripts/.inpaint-sample-after/

# v1 polish audit transient artefacts
.audit-v1-polish.json
scripts/.audit-missing-files.json
scripts/.unscanned-catalogue.json
scripts/.visual-cleanup-v2-delta.ndjson
scripts/.visual-cleanup-v2-delta.err
scripts/.tmp/
scripts/.per-city-min5/dk-cities-backfill.mjs
scripts/.per-city-min5/pexels-api-backfill.mjs
scripts/.per-city-min5/pexels-backfill-playwright.mjs
scripts/.per-city-min5/redownload-missing.mjs
