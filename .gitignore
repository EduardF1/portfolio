# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local working logs
dev.log
install-utils.log
create-next-app.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# test outputs
/playwright-report
/test-results
/coverage

# downloaded design refs (local only)
.refs/
.claude/settings.local.json
.claude/worktrees/

# photo-catalogue intermediates (raw NDJSON dump from extract-exif.ps1)
scripts/.exif-raw.ndjson

# Lighthouse audit raw reports (regenerated via scripts/lighthouse-batch.mjs).
# Keep scores.md committed for historical context; per-route JSONs are
# huge and noisy. Re-run locally when needed.
docs/lighthouse-reports/*.json
