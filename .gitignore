# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local working logs
dev.log
install-utils.log
create-next-app.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# test outputs
/playwright-report
/test-results
/coverage

# downloaded design refs (local only)
.refs/
.claude/settings.local.json
.claude/worktrees/

# photo-catalogue intermediates (raw NDJSON dump from extract-exif.ps1)
scripts/.exif-raw.ndjson

# Lighthouse audit raw reports (regenerated via scripts/lighthouse-batch.mjs).
# Keep scores.md committed for historical context; per-route JSONs are
# huge and noisy. Re-run locally when needed.
docs/lighthouse-reports/*.json
.env*.local

# Scratch dirs from agent runs (Round 4/5 + EXIF tmp)
scripts/.round4/
scripts/.tmp-exif/
scripts/.gposze-*
scripts/.dportfolio-*
scripts/.israel-*
scripts/.catalogue-srcs.txt
scripts/round4-extension-*.json
scripts/.round5/agent-*-scratch/
scripts/.photo-classify/

# Inpaint pipeline (YOLO + LaMa) -- venv, model cache, and worktree-only
# test outputs. The python script (inpaint-people.py) IS committed.
# Re-create with: python -m venv scripts/.inpaint-venv && pip install ultralytics mediapipe Pillow simple-lama-inpainting
scripts/.inpaint-venv/
scripts/.inpaint-cache/
scripts/.inpaint-test-output/
scripts/.inpaint-out/
# Stray YOLO weights if Ultralytics drops them in CWD on first download.
yolo11n.pt
*.pt

# Sub-agent worktrees
.claude/worktrees/

# Transient build outputs (CV PDF builder uses /.cache for transpiled
# TS modules and /tmp for the smoke-test fixture output).
/.cache/
/tmp/

# Inpaint sweep intermediates: thumbnails (regenerated by
# scripts/generate-inpaint-review.mjs), staged inpaint output before sign-off,
# standalone test outputs from the inpaint Python pipeline, and the temporary
# before/after fixtures used by the SAMPLE doc dry-run.
public/photos/_inpaint-thumbs/
scripts/.inpaint-staging/
scripts/.inpaint-test-output/
scripts/.inpaint-sample-before/
scripts/.inpaint-sample-after/
